[Unit]
Description=EasyTech Google OAuth (Business Profile + YouTube)
After=network.target

[Service]
Type=simple
User=papichulo
WorkingDirectory=/opt/easytech_marketing
Environment=PATH=/opt/easytech_marketing/venv/bin
Environment=PYTHONUNBUFFERED=1
ExecStart=/opt/easytech_marketing/venv/bin/python3 /opt/easytech_marketing/Motor_Tecnico/google_oauth.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
