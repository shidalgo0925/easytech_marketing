# Conectores stub — ads

# EasyMarketingOne Accio Engine
ACCIO_API_KEY=CHANGE_ME
# Contraseña inicial del usuario admin del dashboard (usuario: admin)
ACCIO_ADMIN_PASSWORD=CHANGE_ME_TOO
ACCIO_ENGINE_PORT=8092
ACCIO_DEFAULT_TENANT=easytech
# Opcional: clave dedicada para cifrar secretos por tenant (Fernet)
ACCIO_SECRETS_KEY=CHANGE_ME_LONG_RANDOM

# Asistente IA conversacional — vía Accio AI Provider Manager (no OpenAI directo)
AI_ASSISTANT_ENABLED=true
ACCIO_AI_ENABLED=true
# litellm | openai | disabled
ACCIO_AI_PROVIDER=litellm
ACCIO_AI_BASE_URL=http://CODITO_HOST:4000
ACCIO_AI_MODEL=qwen2.5-coder:14b
# ACCIO_AI_API_KEY=
# ACCIO_AI_TIMEOUT=90
# Fallback a OpenAI si LiteLLM falla (requiere OPENAI_API_KEY)
# ACCIO_AI_OPENAI_FALLBACK=true

# Marketing OS platform DB (Sprint 3 M0+M1)
# ACCIO_PLATFORM_DB=/opt/easytech_marketing/Marketing/platform/marketing_os.db
ACCIO_MEMORY_STORE=sql
# VS2 — publicación LinkedIn (modo seguro)
# ACCIO_PUBLISH_ENABLED=true
# ACCIO_LINKEDIN_PUBLISH_ENABLED=true
# ACCIO_PUBLISH_DRY_RUN=false
# Dual-read/write legacy JSON + SQLite (M4–M9)
ACCIO_BRAIN_STORE=dual
ACCIO_BRAND_STORE=dual
ACCIO_PUBLICATION_STORE=dual
ACCIO_PRODUCT_STORE=dual
ACCIO_KNOWLEDGE_STORE=dual
ACCIO_CAMPAIGN_STORE=dual
ACCIO_ASSET_STORE=dual
ACCIO_LEAD_STORE=dual

# Company Brain (M2)
# ACCIO_BRAIN_STORE=json

